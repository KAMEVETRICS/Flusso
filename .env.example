LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_TIMEOUT_MS=180000
OPENAI_TIMEOUT_MS=120000

# Private bearer token used by the VPS ASP agent. Keep the API bound to localhost.
CONTENT_ENGINE_URL=http://127.0.0.1:3107
A2A_INTERNAL_API_KEY=

# Commercial terms for autonomous negotiation. No defaults are assumed.
A2A_PRICE_FLOOR_USDT=
A2A_PRICE_TARGET_USDT=
A2A_OPENING_MARKUP_PERCENT=15
A2A_MAX_GENERATION_ATTEMPTS=3
A2A_JOB_LEASE_SECONDS=900
A2A_RETRY_BASE_SECONDS=60
A2A_MAX_CONVERSATION_RECOVERY_ATTEMPTS=2
A2A_CONVERSATION_RETRY_BASE_SECONDS=30

# Neon pooled connection string
DATABASE_URL=
